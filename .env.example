# =============================================================================
# AI Customer Support SaaS — Environment Configuration
# Copy this to .env and fill in your values
# =============================================================================

# --- Google Gemini LLM ---
GEMINI_API_KEY=your-gemini-api-key-here
LLM_MODEL=gemini-2.0-flash

# --- Endee Vector Database ---
ENDEE_URL=http://localhost:8080
ENDEE_INDEX_NAME=support_kb

# --- MongoDB ---
MONGODB_URL=mongodb://localhost:27017/support_ai

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Embedding Model ---
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# --- Decision Thresholds ---
AUTO_RESOLVE_THRESHOLD=0.82
CLARIFY_THRESHOLD=0.60

# --- Auth ---
JWT_SECRET=change-this-to-a-strong-random-string-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440

# --- Rate Limiting ---
RATE_LIMIT_REQUESTS=20
RATE_LIMIT_WINDOW_SECONDS=60
